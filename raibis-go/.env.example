# Active provider: anthropic | openai | google | ollama
AI_PROVIDER=anthropic

# API keys — only the active provider's key is required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# DB path (default: $HOME/.local/share/raibis/lifeos.db)
LIFEOS_DB=

# HTTP server port (default: 3344)
LIFEOS_PORT=3344

{
  "identifier": "default",
  "description": "Default capabilities for Raibis LifeOS",
  "windows": ["main", "hud"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister-all",
    "global-shortcut:allow-is-registered"
  ]
}

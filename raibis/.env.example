# ──────────────────────────────────────────
# Raibis — AI Provider Configuration
# ──────────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Only the active provider's key(s) are required.

# Active provider: anthropic | openai | google | ollama
AI_PROVIDER=anthropic

# ── Anthropic (Claude) ─────────────────────
# Option 1: Personal API key (direct to Anthropic)
ANTHROPIC_API_KEY=

# Option 2: Work proxy (e.g. Hyperspace AI / SAP internal)
# When both proxy vars are set, they take priority over the personal key.
ANTHROPIC_PROXY_URL=
ANTHROPIC_PROXY_KEY=

# ── OpenAI (GPT) ───────────────────────────
OPENAI_API_KEY=

# ── Google (Gemini) ────────────────────────
GOOGLE_API_KEY=

# ── Ollama (local — no key needed) ─────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Storage ────────────────────────────────
DB_PATH=data/raibis.db
